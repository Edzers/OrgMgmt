@using OrgMgmt.Controllers
@model OrgMgmt.Controllers.ShiftAssignmentViewModel

@{
    ViewData["Title"] = "Assign Shifts";
}

<h1>Assign Shifts</h1>

<form asp-action="Assign">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Employee</th>
                @foreach (var shift in Model.Shifts)
                {
                    <th>
                        @shift.Name<br/>
                        <small>@shift.DaysOfWeek @shift.StartTime.ToString(@"hh\:mm")-@shift.EndTime.ToString(@"hh\:mm")</small>
                    </th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var emp in Model.Employees)
            {
                <tr>
                    <td>
                        @emp.Name
                        <br/>
                        <small class="text-muted">@emp.GetType().Name</small>
                    </td>
                    @foreach (var shift in Model.Shifts)
                    {
                        var isChecked = emp.Shifts.Any(s => s.Id == shift.Id);
                        <td class="text-center">
                            <input type="checkbox" 
                                   name="EmployeeShifts[@emp.ID]" 
                                   value="@shift.Id" 
                                   @(isChecked ? "checked" : "") />
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>

    <div class="form-group">
        <input type="submit" value="Save Assignments" class="btn btn-primary btn-lg" />
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>
