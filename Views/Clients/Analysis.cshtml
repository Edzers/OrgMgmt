@model IEnumerable<OrgMgmt.Models.Client>

@{
    ViewData["Title"] = "Data Analysis";
    // Access the City Stats we put in the ViewBag
    var cityStats = ViewBag.CityStats as IEnumerable<dynamic>;
}

<div class="container">
    <h1 class="mt-4">Assignment Reports</h1>
    <hr />

    @* --- Query 1: Clients per City --- *@
    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Query 1: Clients per City (Ordered Alphabetically)</h5>
        </div>
        <div class="card-body">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>City Name (Address)</th>
                        <th>Number of Clients</th>
                    </tr>
                </thead>
                <tbody>
                    @if (cityStats != null)
                    {
                        @foreach (var item in cityStats)
                        {
                            <tr>
                                <td>@item.City</td>
                                <td><span class="badge bg-secondary">@item.Count</span></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* --- Query 2: Idle Clients --- *@
    <div class="card">
        <div class="card-header bg-warning text-dark">
            <h5 class="mb-0">Query 2: Idle Clients (No Registered Services)</h5>
        </div>
        <div class="card-body">
            @if (Model?.Any() == true)
            {
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Client Name</th>
                            <th>Address</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var client in Model)
                        {
                            <tr>
                                <td>@client.Name</td>
                                <td>@client.Address</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-info">
                    All clients are currently registered for at least one service.
                </div>
            }
        </div>
    </div>
    
    <div class="mt-3">
        <a asp-action="Index" class="btn btn-outline-secondary">Back to Clients List</a>
    </div>
</div>